# ============================================================
#  Backend environment variables — copy to .env and fill in
# ============================================================

# ── Colab / ngrok endpoint ───────────────────────────────────
# Paste your static ngrok URL here (from ngrok dashboard or --url flag)
COLAB_ENDPOINT=https://your-static-ngrok-url.ngrok-free.app/generate

# ── Server ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── SQLite checkpoint ────────────────────────────────────────
SQLITE_DB_PATH=./db/conversations.db

# ── CORS — comma-separated list of allowed frontend origins ──
ALLOWED_ORIGINS=http://localhost:3457,http://127.0.0.1:3457,http://localhost:5500

# ── Tuning ──────────────────────────────────────────────────
# Seconds to wait for Colab to respond
REQUEST_TIMEOUT=90.0

# How many past message pairs to send as context to Colab
MAX_HISTORY_PAIRS=5
