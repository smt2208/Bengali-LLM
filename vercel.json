{
  "rewrites": [
    { "source": "/", "destination": "/frontend/pages/index.html" },
    { "source": "/chat", "destination": "/frontend/pages/chat.html" },
    { "source": "/chat.html", "destination": "/frontend/pages/chat.html" },
    { "source": "/pages/index.html", "destination": "/frontend/pages/index.html" },
    { "source": "/pages/chat.html", "destination": "/frontend/pages/chat.html" },
    { "source": "/styles/:path*", "destination": "/frontend/styles/:path*" },
    { "source": "/scripts/:path*", "destination": "/frontend/scripts/:path*" },
    { "source": "/assets/:path*", "destination": "/frontend/assets/:path*" }
  ]
}
